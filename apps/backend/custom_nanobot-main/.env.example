# OptiTrade Nanobot — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# ── LLM Provider (pick one) ──────────────────────────────────────────────────
# OpenAI
NANOBOT_PROVIDERS__OPENAI__API_KEY=sk-...

# Anthropic (optional)
# NANOBOT_PROVIDERS__ANTHROPIC__API_KEY=sk-ant-...

# DeepSeek (optional)
# NANOBOT_PROVIDERS__DEEPSEEK__API_KEY=...

# ── API Server ────────────────────────────────────────────────────────────────
# Dev:  127.0.0.1 (localhost only)
# Prod: 0.0.0.0   (all interfaces — put behind nginx/caddy reverse proxy)
NANOBOT_BIND_HOST=127.0.0.1
NANOBOT_API_PORT=8900

# Workspace directory on the HOST (mounted into the container)
NANOBOT_WORKSPACE_DIR=~/.nanobot/optitrade-workspace

# ── CORS (frontend origin) ────────────────────────────────────────────────────
# Dev:  http://localhost:3000
# Prod: https://your-optitrade-domain.com
NANOBOT_CORS_ORIGIN=http://localhost:3000
